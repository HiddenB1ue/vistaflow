# 数据库（必填）
DATABASE_URL=postgresql://user:password@localhost:5432/vistaflow

# Redis（可选，默认 redis://localhost:6379/2）
REDIS_URL=redis://localhost:6379/2

# CORS（生产环境填写前端域名）
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# 应用
APP_ENV=development
APP_VERSION=1.0.0

# 管理员认证
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_password_here
# ADMIN_TOKEN 会在首次登录时自动生成，也可手动指定
ADMIN_TOKEN=
