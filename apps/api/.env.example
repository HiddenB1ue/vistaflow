# 数据库
DATABASE_URL=postgresql://vistaflow:vistaflow@localhost:5432/vistaflow

# CORS（生产环境填写前端域名）
CORS_ORIGINS=["http://localhost:5173"]

# 12306 票价增强（可选，留空则禁用票价查询）
TICKET_12306_COOKIE=

# 高德地图（可选，站点坐标补全任务需要）
AMAP_API_KEY=
AMAP_MAX_RETRIES=3
AMAP_RETRY_DELAY_SECONDS=1.0
AMAP_MIN_INTERVAL_SECONDS=0.35
AMAP_RATE_LIMIT_COOLDOWN_SECONDS=3.0

# 应用
APP_ENV=development
APP_VERSION=1.0.0
